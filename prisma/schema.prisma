datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum IpoStatus {
  UPCOMING
  OPEN
  CLOSED
  LISTED
}

enum AllotmentStatus {
  PENDING
  ALLOTTED
  NOT_ALLOTTED
}

model Account {
  id            String        @id @default(uuid())
  accountName   String
  panNumber     String        @unique
  bankName      String
  accountNumber String
  upiId         String
  phoneNumber   String
  status        AccountStatus @default(ACTIVE)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  applications  Application[]
}

model Ipo {
  id               String            @id @default(uuid())
  ipoName          String
  openDate         DateTime
  closeDate        DateTime
  listingDate      DateTime
  issuePrice       Float
  lotSize          Int
  status           IpoStatus         @default(UPCOMING)
  externalId       String?
  createdAt        DateTime          @default(now())
  applications     Application[]
  allotmentImports AllotmentImport[]
}

model Application {
  id              String              @id @default(uuid())
  accountId       String
  ipoId           String
  amountSent      Float
  commissionPaid  Float
  applicationDate DateTime            @default(now())
  allotmentStatus AllotmentStatus     @default(PENDING)
  sharesAllotted  Int                 @default(0)
  soldPrice       Float?
  sellDate        DateTime?
  notes           String?
  
  // Relations
  account      Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ipo          Ipo                 @relation(fields: [ipoId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  auditLogs    AllotmentAuditLog[]
  
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

enum TransactionType {
  DEPLOYMENT
  REFUND
  COMMISSION
  SALE
}

model Transaction {
  id            String          @id @default(uuid())
  applicationId String
  type          TransactionType
  amount        Float
  remarks       String?
  createdAt     DateTime        @default(now())
  
  // Relations
  application   Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Setting {
  id                     String  @id @default("default")
  defaultCommission     Float   @default(0.0)
  currency               String  @default("INR")
  profitCalculationRules String  @default("STANDARD")
}

model AllotmentCheck {
  id             String          @id @default(uuid())
  panNumber      String
  ipoId          String
  status         AllotmentStatus
  sharesAllotted Int             @default(0)
  source         String          // "MANUAL" | "CSV" | "API"
  checkedAt      DateTime        @default(now())
}

model AllotmentImport {
  id           String   @id @default(uuid())
  ipoId        String
  fileName     String
  successCount Int
  failedCount  Int
  importedAt   DateTime @default(now())
  
  // Relations
  ipo          Ipo      @relation(fields: [ipoId], references: [id], onDelete: Cascade)
}

model AllotmentAuditLog {
  id             String          @id @default(uuid())
  applicationId  String
  updatedBy      String          // e.g. "Admin / System"
  previousStatus AllotmentStatus
  newStatus      AllotmentStatus
  timestamp      DateTime        @default(now())
  source         String          // "MANUAL" | "CSV" | "API"
  
  // Relations
  application    Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}
